# API Configuration
NEXT_PUBLIC_API_URL=https://api.example.com

# RPC Provider
NEXT_PUBLIC_INFURA_API_KEY=your_infura_api_key_here

# WalletConnect (optional)
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_project_id_here

# The Graph API Key (for codegen and subgraph queries)
THEGRAPH_API_KEY=your_thegraph_api_key_here

# Yield Optimizer API
OPTIMIZER_API_URL=https://yieldoptimizer-api.onrender.com

# PostgreSQL (Neon) — pooled URL for the app runtime
DATABASE_URL=postgres://<user>:<password>@<endpoint>-pooler.<region>.aws.neon.tech/<db>?sslmode=require
# PostgreSQL (Neon) — direct (unpooled) URL for drizzle-kit migrations
DATABASE_URL_UNPOOLED=postgres://<user>:<password>@<endpoint>.<region>.aws.neon.tech/<db>?sslmode=require
