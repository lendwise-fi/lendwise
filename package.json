{
  "name": "yieldoptimizer",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "preinstall": "pnpx only-allow pnpm",
    "db:init": "dotenv -- tsx scripts/db-init.ts",
    "products:sync": "dotenv -- tsx scripts/products-sync.ts",
    "apy:backfill": "dotenv -- tsx scripts/apy-history-backfill.ts",
    "apy:enrich-market": "dotenv -- tsx scripts/apy-market-enrich.ts",
    "apy:migrate-slugs": "dotenv -- tsx scripts/apy-migrate-chain-slugs.ts",
    "products:clean-inactive": "dotenv -- tsx scripts/products-clean-inactive.ts",
    "apy:fix-quality": "dotenv -- tsx scripts/apy-daily-fix-quality.ts",
    "apy:rename-productid": "dotenv -- tsx scripts/apy-rename-productid.ts",
    "apy:daily-migrate-ids": "dotenv -- tsx scripts/apy-daily-migrate-ids.ts",
    "dev": "next dev",
    "build": "pnpm codegen && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "clean": "rm -rf node_modules pnpm-lock.yaml .next",
    "clean:cache": "rm -rf .next",
    "reinstall": "pnpm clean && pnpm install",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:clean": "find src -type d -name 'generated' -exec rm -rf {} + 2>/dev/null || true && pnpm codegen",
    "codegen:optimizer": "dotenv -- bash -c 'openapi-typescript $OPTIMIZER_API_URL/openapi.json -o src/lib/api/optimizer.generated.ts'"
  },
  "dependencies": {
    "@graphql-typed-document-node/core": "^3.2.0",
    "@metamask/connect-multichain": "^0.15.0",
    "@metamask/sdk": "^0.34.0",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@rainbow-me/rainbowkit": "^2.2.9",
    "@tanstack/react-form": "^1.28.0",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-table": "^8.21.3",
    "@upstash/qstash": "^2.9.0",
    "@urql/core": "^6.0.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/functions": "^3.4.2",
    "@wagmi/core": "^2.20.2",
    "@zerodev/ecdsa-validator": "^5.4.9",
    "@zerodev/presets": "^5.3.3",
    "@zerodev/sdk": "^5.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cryptocurrency-icons": "^0.18.1",
    "currency-list": "^1.0.8",
    "date-fns": "^4.1.0",
    "ethereum-blockies-base64": "^1.0.2",
    "financial-flag-icons": "^1.0.5",
    "graphql-yoga": "^5.18.0",
    "lucide-react": "^0.545.0",
    "mongodb": "^7.1.0",
    "motion": "^12.23.24",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "pino-pretty": "^13.0.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-jazzicon": "^1.0.4",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "urql": "^5.0.1",
    "vaul": "^1.1.2",
    "viem": "2.38.3",
    "wagmi": "2.16.8",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "6.0.1",
    "@graphql-codegen/client-preset": "5.1.0",
    "@mongodb-js/zstd": "^7.0.0",
    "@next/eslint-plugin-next": "^16.2.6",
    "@tailwindcss/postcss": "^4",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^22.18.12",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "baseline-browser-mapping": "^2.9.19",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^16.5.0",
    "graphql": "^16.11.0",
    "openapi-typescript": "^7.10.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "typescript-eslint": "^8.46.2"
  }
}
