{
    "name": "Protocol",
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "description": "Protocol name"
      },
      "blockchain": {
        "type": "string",
        "enum": [
          "ethereum",
          "polygon",
          "arbitrum",
          "optimism",
          "avalanche",
          "bsc"
        ],
        "description": "Primary blockchain"
      },
      "tvl": {
        "type": "number",
        "description": "Total Value Locked in USD"
      },
      "category": {
        "type": "string",
        "enum": [
          "lending",
          "dex",
          "yield_farming",
          "derivatives"
        ],
        "description": "Protocol category"
      },
      "risk_score": {
        "type": "number",
        "minimum": 1,
        "maximum": 10,
        "description": "Risk assessment score (1-10)"
      },
      "audit_status": {
        "type": "string",
        "enum": [
          "audited",
          "partially_audited",
          "unaudited"
        ],
        "description": "Security audit status"
      },
      "logo_url": {
        "type": "string",
        "description": "Protocol logo URL"
      }
    },
    "required": [
      "name",
      "blockchain",
      "category"
    ]
  }